[gd_scene format=3 uid="uid://main_menu_scene"]

[ext_resource type="Script" path="res://scenes/menu/main_menu.gd" id="1_menu"]
[ext_resource type="SpriteFrames" path="res://assets/menu/menu.tres" id="2_menu"]

; ── Main container (fills 240×100 canvas) ────────────────────────────────────
[node name="MainMenu" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_menu")

; ── Title animated sprite – centered at (120, 32) ────────────────────────────
[node name="Title" type="AnimatedSprite2D" parent="."]
position = Vector2(120, 44)
sprite_frames = ExtResource("2_menu")
animation = &"default"
autoplay = "default"

; ── Play button – anchored to lower centre ───────────────────────────────────
[node name="PlayBtn" type="Button" parent="."]
anchor_left   = 0.5
anchor_top    = 0.0
anchor_right  = 0.5
anchor_bottom = 0.0
offset_left   = -18.0
offset_top    = 68.0
offset_right  =  18.0
offset_bottom =  82.0
text = "▶  PLAY"
focus_mode = 2

; ── Scanline overlay (TextureRect, filled by script) ─────────────────────────
[node name="Scanlines" type="TextureRect" parent="."]
anchor_right  = 1.0
anchor_bottom = 1.0
mouse_filter  = 2
